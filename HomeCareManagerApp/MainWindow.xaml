<Window x:Class="HomeCareManagerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HomeCare Manager"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.Resources>
        <SolidColorBrush x:Key="BlueBrush" Color="#1565C0" />
        <SolidColorBrush x:Key="BlueSoftBrush" Color="#F4F9FF" />
        <SolidColorBrush x:Key="TealBrush" Color="#00897B" />
        <SolidColorBrush x:Key="GoldBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="TextBrush" Color="#1A2340" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5F6F8D" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D9E2EF" />

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#DCEBFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B7DD2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E3F2FD" />
            <Setter Property="Foreground" Value="#1565C0" />
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,6,0,12" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="17*"/>
            <RowDefinition Height="45*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BlueBrush}" Grid.RowSpan="2">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="HomeCare Manager"
                               Foreground="White"
                               FontSize="21"
                               FontWeight="Bold" />
                    <TextBlock Text="Care coordination"
                               Foreground="#BFD9F8"
                               FontSize="13"
                               Margin="0,3,0,24" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,18,0,0">
                    <Button x:Name="DashboardNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Tag="Dashboard"
                            Click="Navigate_Click"
                            Content="Dashboard" />
                    <Button x:Name="PatientsNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Tag="Pacientes"
                            Click="Navigate_Click"
                            Content="Pacientes" />
                    <Button x:Name="TasksNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Tag="Tareas"
                            Click="Navigate_Click"
                            Content="Tareas" />
                    <Button x:Name="IncidentsNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Tag="Incidencias"
                            Click="Navigate_Click"
                            Content="Incidencias" />
                    <Button x:Name="AdminNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Tag="Administracion"
                            Click="Navigate_Click"
                            Content="Administracion" />
                </StackPanel>

                <Border Grid.Row="2"
                        Background="#1E73C8"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="Admin"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="alvaro.juan@homecare.local"
                                   Foreground="#CFE5FF"
                                   FontSize="12"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText"
                                   Text="Dashboard"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock x:Name="PageSubtitleText"
                                   Text="Resumen operativo del servicio de atencion domiciliaria"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="Nueva tarea"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="OpenCreateTask_Click" />
                        <Button Content="Sincronizar"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ShowPendingIntegration_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="28">
                    <Grid x:Name="DashboardView">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="4">
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Pacientes activos" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="24" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
                                    <TextBlock Text="3 con prioridad alta" Foreground="{StaticResource TealBrush}" FontSize="12" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Tareas pendientes" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="17" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
                                    <TextBlock Text="6 sin asignar" Foreground="{StaticResource GoldBrush}" FontSize="12" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Cuidadores" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="8" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
                                    <TextBlock Text="5 disponibles hoy" Foreground="{StaticResource TealBrush}" FontSize="12" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Incidencias" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="2" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
                                    <TextBlock Text="Requieren seguimiento" Foreground="#D97706" FontSize="12" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.35*" />
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Tareas de hoy" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                    <ListView Margin="0,14,0,0" BorderThickness="0">
                                        <ListViewItem Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Administrar medicacion" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="Paciente: Maria Lopez - Zona Norte" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#FFF8E1" CornerRadius="8" Padding="10,4">
                                                    <TextBlock Text="Alta" Foreground="#9A6500" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </ListViewItem>
                                        <ListViewItem Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Revision de constantes" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="Paciente: Luis Martin - Centro" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#E0F2F1" CornerRadius="8" Padding="10,4">
                                                    <TextBlock Text="Media" Foreground="{StaticResource TealBrush}" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </ListViewItem>
                                        <ListViewItem Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Apoyo en movilidad" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="Paciente: Ana Ruiz - Zona Este" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="8" Padding="10,4">
                                                    <TextBlock Text="Pendiente" Foreground="{StaticResource BlueBrush}" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </ListViewItem>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#E0F2F1" BorderBrush="#C7E7E3" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Flujo de servicio" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                    <TextBlock Text="1. Crear paciente" Foreground="{StaticResource TextBrush}" Margin="0,16,0,6" />
                                    <TextBlock Text="2. Crear tarea vinculada" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="3. Asignar por zona y habilidad" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="4. Aceptar, completar y reportar" Foreground="{StaticResource TextBrush}" />
                                    <Border Background="White" BorderBrush="#C7E7E3" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,18,0,0">
                                        <TextBlock Text="El siguiente paso tecnico es conectar estos paneles a una libreria compartida con tus modelos y consultas parametrizadas."
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Actividad reciente" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                <UniformGrid Columns="3" Margin="0,16,0,0">
                                    <TextBlock Text="09:10 - Tarea aceptada por Carmen" Foreground="{StaticResource MutedBrush}" Margin="0,0,14,0" />
                                    <TextBlock Text="10:25 - Paciente nuevo registrado" Foreground="{StaticResource MutedBrush}" Margin="0,0,14,0" />
                                    <TextBlock Text="11:00 - Incidencia cerrada" Foreground="{StaticResource MutedBrush}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="PatientsView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Height="38" Padding="12,0" VerticalContentAlignment="Center" Text="Buscar paciente por nombre, zona o prioridad" Foreground="{StaticResource MutedBrush}" />
                                <ComboBox Grid.Column="1" Height="38" Margin="12,0" SelectedIndex="0">
                                    <ComboBoxItem Content="Todas las zonas" />
                                    <ComboBoxItem Content="Zona Norte" />
                                    <ComboBoxItem Content="Centro" />
                                    <ComboBoxItem Content="Zona Este" />
                                </ComboBox>
                                <Button Grid.Column="2" Content="Nuevo paciente" Style="{StaticResource PrimaryButtonStyle}" Click="ShowPendingIntegration_Click" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Pacientes" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                    <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" Margin="0,14,0,0" ItemsSource="{Binding Patients}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Zona" Binding="{Binding Zone}" Width="120" />
                                            <DataGridTextColumn Header="Prioridad" Binding="{Binding Priority}" Width="100" />
                                            <DataGridTextColumn Header="Telefono" Binding="{Binding Phone}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Ficha rapida" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                    <TextBlock Text="Maria Lopez" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,16,0,4" />
                                    <TextBlock Text="Calle Mayor 18, Zona Norte" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="Notas" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,18,0,6" />
                                    <TextBlock Text="Necesita seguimiento diario de medicacion y ayuda para desplazamientos largos."
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap" />
                                    <Button Content="Ver historial" Style="{StaticResource SecondaryButtonStyle}" Margin="0,18,0,0" Click="ShowPendingIntegration_Click" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid x:Name="TasksView" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Crear tarea" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                <TextBlock Text="Paciente" Style="{StaticResource FieldLabelStyle}" Margin="0,18,0,2" />
                                <ComboBox Height="36" SelectedIndex="0">
                                    <ComboBoxItem Content="Maria Lopez" />
                                    <ComboBoxItem Content="Luis Martin" />
                                    <ComboBoxItem Content="Ana Ruiz" />
                                </ComboBox>
                                <TextBlock Text="Descripcion" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,2" />
                                <TextBox Height="82" TextWrapping="Wrap" AcceptsReturn="True" Text="Administrar medicacion y registrar observaciones." />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Fecha" Style="{StaticResource FieldLabelStyle}" />
                                        <DatePicker Height="36" SelectedDate="{x:Static sys:DateTime.Today}" xmlns:sys="clr-namespace:System;assembly=mscorlib" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Prioridad" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox Height="36" SelectedIndex="0">
                                            <ComboBoxItem Content="Alta" />
                                            <ComboBoxItem Content="Media" />
                                            <ComboBoxItem Content="Baja" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Cuidador asignado" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,2" />
                                <ComboBox Height="36" SelectedIndex="0">
                                    <ComboBoxItem Content="Asignacion automatica" />
                                    <ComboBoxItem Content="Carmen Diaz" />
                                    <ComboBoxItem Content="Pablo Sanz" />
                                </ComboBox>
                                <Button Content="Guardar tarea" Style="{StaticResource PrimaryButtonStyle}" Margin="0,18,0,0" Click="ShowPendingIntegration_Click" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Estado de tareas" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                <ListBox Margin="0,14,0,0" BorderThickness="0">
                                    <ListBoxItem Content="Pendiente - Revision de constantes" Padding="0,8" />
                                    <ListBoxItem Content="Aceptada - Apoyo en movilidad" Padding="0,8" />
                                    <ListBoxItem Content="Disponible - Cura basica" Padding="0,8" />
                                    <ListBoxItem Content="Completada - Control de medicacion" Padding="0,8" />
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="IncidentsView" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>

                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Incidencias abiertas" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" Margin="0,14,0,0" ItemsSource="{Binding Incidents}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Paciente" Binding="{Binding Patient}" Width="*" />
                                        <DataGridTextColumn Header="Tarea" Binding="{Binding Task}" Width="*" />
                                        <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FFF8E1" BorderBrush="#F3D58B" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Seguimiento" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                <TextBlock Text="Las incidencias deben quedar vinculadas a una tarea y a un cuidador para mantener la trazabilidad."
                                           Foreground="#6B5A2B"
                                           TextWrapping="Wrap"
                                           Margin="0,14,0,0" />
                                <Button Content="Registrar incidencia" Style="{StaticResource PrimaryButtonStyle}" Background="{StaticResource GoldBrush}" Margin="0,18,0,0" Click="ShowPendingIntegration_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="AdminView" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Usuarios y roles" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" Margin="0,14,0,0" ItemsSource="{Binding Users}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="130" />
                                        <DataGridTextColumn Header="Activo" Binding="{Binding Active}" Width="80" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button Content="Nuevo usuario" Style="{StaticResource SecondaryButtonStyle}" Margin="0,16,0,0" Click="ShowPendingIntegration_Click" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Configuracion inicial" Style="{StaticResource SectionTitleStyle}" FontSize="18" />
                                <TextBlock Text="Antes de conectar la aplicacion, conviene crear una libreria compartida con los modelos, Data.cs y la cadena de conexion."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,14,0,18" />
                                <CheckBox Content="Base de datos creada con HomeCareManager.sql" IsChecked="True" Margin="0,0,0,8" />
                                <CheckBox Content="Consultas parametrizadas" IsChecked="True" Margin="0,0,0,8" />
                                <CheckBox Content="Proyecto Core compartido" IsChecked="False" Margin="0,0,0,8" />
                                <CheckBox Content="Pantallas conectadas a MySQL" IsChecked="False" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
